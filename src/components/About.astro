---
import site from '../content/site.json';
---

<section id="about" class="section-padding bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="fade-in mb-12 text-center">
      <h2 class="section-title">{site.about.title}</h2>
    </div>

    <div class="grid items-start gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="fade-in">
        <img
          src={site.psychologist.photo}
          alt={`${site.psychologist.name} — психолог`}
          class="mb-8 aspect-[4/5] w-full max-w-sm rounded-2xl object-cover shadow-card lg:mb-0"
          width="400"
          height="500"
          loading="lazy"
        />
      </div>

      <div class="fade-in space-y-6">
        <div class="space-y-5 text-lg leading-relaxed text-stone-muted">
          {
            site.about.paragraphs.map((paragraph) => (
              <p>{paragraph}</p>
            ))
          }
        </div>

        <div class="card border-l-4 border-sage bg-sage/5">
          <h3 class="mb-4 font-serif text-xl font-medium text-stone">Образование и опыт</h3>
          <ul class="space-y-3">
            {
              site.about.credentials.map((item) => (
                <li class="flex gap-3 text-stone-muted">
                  <svg class="mt-1 h-5 w-5 shrink-0 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          {site.about.credentialsNote && (
            <p class="mt-4 text-sm italic text-stone-muted/80">{site.about.credentialsNote}</p>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
