---
import site from '../content/site.json';
import reviews from '../content/b17-reviews.json';

const marqueeReviews = [...reviews, ...reviews];
---

<section id="testimonials" class="section-padding overflow-hidden bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="fade-in mb-12 text-center">
      <h2 class="section-title">{site.testimonials.title}</h2>
      <p class="section-subtitle mx-auto">{site.testimonials.subtitle}</p>
    </div>
  </div>

  {
    reviews.length > 0 && (
      <div class="fade-in">
        <div class="testimonials-marquee" aria-label="Лента отзывов клиентов">
          <div class="testimonials-marquee-track">
            {marqueeReviews.map((item, index) => (
              <article
                class="testimonials-marquee-card"
                aria-hidden={index >= reviews.length ? 'true' : undefined}
              >
                <svg class="mb-3 h-7 w-7 text-sage/35" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                </svg>
                <p class="mb-4 flex-1 text-sm leading-relaxed text-stone-muted line-clamp-6">{item.text}</p>
                <div class="mt-auto">
                  <p class="text-sm font-medium text-sage">{item.author}</p>
                  {item.date && <p class="mt-0.5 text-xs text-stone-muted/70">{item.date}</p>}
                </div>
              </article>
            ))}
          </div>
        </div>
        <p class="mx-auto mt-8 max-w-6xl px-4 text-center text-sm text-stone-muted sm:px-6 lg:px-8">
          Отзывы с платформы{' '}
          <a
            href="https://www.b17.ru/marina8/#otzyv"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sage underline-offset-2 hover:underline"
          >
            b17.ru
          </a>
        </p>
      </div>
    )
  }
</section>
