---
import site from '../content/site.json';

const icons: Record<string, string> = {
  heart: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z',
  sun: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
  users: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
  compass: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7',
  star: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
};
---

<section id="services" class="section-padding">
  <div class="mx-auto max-w-6xl">
    <div class="fade-in mb-12 text-center">
      <h2 class="section-title">{site.services.title}</h2>
      <p class="section-subtitle mx-auto">{site.services.subtitle}</p>
    </div>

    <div class="fade-in mb-12 grid items-center gap-8 overflow-hidden rounded-2xl bg-white p-6 shadow-card lg:grid-cols-2 lg:p-8">
      <img
        src={site.images.familyTree}
        alt="Семейные корни и внутренняя опора — символ работы с отношениями и самопознанием"
        class="mx-auto max-h-80 w-full rounded-xl object-contain"
        width="400"
        height="500"
        loading="lazy"
      />
      <div class="text-center lg:text-left">
        <h3 class="mb-3 font-serif text-2xl font-medium text-stone">Работа с семейными сценариями</h3>
        <p class="text-stone-muted leading-relaxed">
          Многие наши паттерны уходят корнями в семейную историю. В работе мы исследуем не только текущие трудности,
          но и то, как прошлый опыт влияет на вашу жизнь сегодня — чтобы обрести опору и двигаться вперёд осознанно.
        </p>
      </div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        site.services.items.map((service, index) => (
          <div
            class:list={[
              'card fade-in',
              index === site.services.items.length - 1 && site.services.items.length % 3 !== 0 && 'sm:col-span-2 lg:col-span-1',
            ]}
            style={`transition-delay: ${index * 80}ms`}
          >
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-sage/10">
              <svg class="h-6 w-6 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d={icons[service.icon] || icons.heart}
                />
              </svg>
            </div>
            <h3 class="mb-3 font-serif text-xl font-medium text-stone">{service.title}</h3>
            <p class="text-stone-muted leading-relaxed">{service.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
