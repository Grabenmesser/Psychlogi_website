---
import site from '../content/site.json';
const year = new Date().getFullYear();
---

<footer class="border-t border-stone/5 bg-cream py-12">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="text-center md:text-left">
        <p class="font-serif text-xl font-medium text-stone">{site.psychologist.name}</p>
        <p class="text-sm text-stone-muted">{site.psychologist.title}</p>
      </div>

      <div class="flex flex-wrap justify-center gap-6 text-sm text-stone-muted">
        <a href={`tel:${site.contact.phone.replace(/[^\d+]/g, '')}`} class="transition-colors hover:text-sage">
          {site.contact.phone}
        </a>
        {site.contact.email && (
          <a href={`mailto:${site.contact.email}`} class="transition-colors hover:text-sage">
            {site.contact.email}
          </a>
        )}
      </div>
    </div>

    <div class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-stone/5 pt-8 text-sm text-stone-muted sm:flex-row">
      <p>&copy; {year} {site.psychologist.name}. Все права защищены.</p>
      <a href="/privacy" class="transition-colors hover:text-sage">
        Политика конфиденциальности
      </a>
    </div>
  </div>
</footer>
