---
import site from '../content/site.json';
---

<section id="process" class="section-padding bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="fade-in mb-12 text-center">
      <h2 class="section-title">{site.process.title}</h2>
      {site.process.subtitle && (
        <p class="section-subtitle mx-auto">{site.process.subtitle}</p>
      )}
    </div>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      {
        site.process.steps.map((step, index) => (
          <div class="fade-in relative" style={`transition-delay: ${index * 100}ms`}>
            {index < site.process.steps.length - 1 && (
              <div
                class="absolute left-1/2 top-8 hidden h-0.5 w-full bg-sage/20 lg:block"
                aria-hidden="true"
              />
            )}
            <div class="relative text-center">
              <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-sage text-xl font-bold text-white">
                {step.number}
              </div>
              <h3 class="mb-2 font-serif text-xl font-medium text-stone">{step.title}</h3>
              <p class="text-sm text-stone-muted leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
