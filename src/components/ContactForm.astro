---
import site from '../content/site.json';

const formEndpoint = `https://formsubmit.co/ajax/${site.meta.formEmail}`;
const notifyEmail = site.meta.formEmail;
---

<section id="contact" class="section-padding bg-white">
  <div class="mx-auto max-w-6xl">
    <div class="fade-in mb-12 text-center">
      <h2 class="section-title">{site.contact.title}</h2>
      <p class="section-subtitle mx-auto">{site.contact.subtitle}</p>
    </div>

    <div class="grid gap-12 lg:grid-cols-2">
      <div class="fade-in space-y-6">
        <div class="card">
          <h3 class="mb-6 font-serif text-2xl font-medium text-stone">Контакты</h3>
          <div class="space-y-4">
            <a href={`tel:${site.contact.phone.replace(/[^\d+]/g, '')}`} class="flex items-center gap-3 text-stone-muted transition-colors hover:text-sage">
              <svg class="h-5 w-5 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {site.contact.phone}
            </a>
            {site.contact.email && (
              <a href={`mailto:${site.contact.email}`} class="flex items-center gap-3 text-stone-muted transition-colors hover:text-sage">
                <svg class="h-5 w-5 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                {site.contact.email}
              </a>
            )}
          </div>

          <div class="mt-6 flex gap-3">
            <a
              href={site.contact.telegram}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-11 w-11 items-center justify-center rounded-full bg-sage/10 text-sage transition-colors hover:bg-sage hover:text-white"
              aria-label="Telegram"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z" />
              </svg>
            </a>
            <a
              href={site.contact.max}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-11 w-11 items-center justify-center rounded-full bg-sage/10 text-sage transition-colors hover:bg-sage hover:text-white"
              aria-label="MAX"
            >
              <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm1.75 4.5v9h2.15V12.2l2.35 4.3h.5l2.35-4.3v4.6h2.15v-9h-2.55L12.2 12.4 9.85 7.5H6.75z" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <div class="fade-in" style="transition-delay: 100ms">
        <form id="contact-form" class="card space-y-5" novalidate>
          <div>
            <label for="name" class="mb-2 block text-sm font-medium text-stone">
              {site.contact.form.nameLabel} <span class="text-sage">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              class="w-full rounded-xl border border-stone/10 bg-cream px-4 py-3 text-stone transition-colors focus:border-sage focus:outline-none focus:ring-2 focus:ring-sage/20"
            />
          </div>

          <div>
            <label for="phone" class="mb-2 block text-sm font-medium text-stone">
              {site.contact.form.phoneLabel} <span class="text-sage">*</span>
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              autocomplete="tel"
              inputmode="tel"
              pattern="[\d\s\+\-\(\)]{10,}"
              title="Введите корректный номер телефона"
              class="w-full rounded-xl border border-stone/10 bg-cream px-4 py-3 text-stone transition-colors focus:border-sage focus:outline-none focus:ring-2 focus:ring-sage/20"
            />
          </div>

          <div>
            <label for="message" class="mb-2 block text-sm font-medium text-stone">
              {site.contact.form.messageLabel}
            </label>
            <textarea
              id="message"
              name="message"
              rows="4"
              placeholder={site.contact.form.messagePlaceholder}
              class="w-full resize-none rounded-xl border border-stone/10 bg-cream px-4 py-3 text-stone transition-colors focus:border-sage focus:outline-none focus:ring-2 focus:ring-sage/20"
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input
              type="checkbox"
              id="consent"
              name="consent"
              required
              value="yes"
              class="mt-1 h-4 w-4 rounded border-stone/20 text-sage focus:ring-sage"
            />
            <label for="consent" class="text-sm text-stone-muted">
              {site.contact.form.consentLabel}.
              <a href="/privacy" class="text-sage underline hover:text-sage-dark">
                Политика конфиденциальности
              </a>
            </label>
          </div>

          <!-- Honeypot for bots -->
          <input
            type="text"
            name="_gotcha"
            tabindex="-1"
            autocomplete="off"
            class="absolute -left-[9999px] h-0 w-0 opacity-0"
            aria-hidden="true"
          />

          <button type="submit" class="btn-primary w-full" id="submit-btn">
            {site.contact.form.submitLabel}
          </button>

          <p id="form-success" class="hidden rounded-xl bg-sage/10 p-4 text-center text-sage" role="status">
            {site.contact.form.successMessage}
          </p>
          <p id="form-error" class="hidden rounded-xl bg-red-50 p-4 text-center text-red-600" role="alert"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script
  define:vars={{
    formEndpoint,
    notifyEmail,
    submitLabel: site.contact.form.submitLabel,
    successMessage: site.contact.form.successMessage,
  }}
>
  const form = document.getElementById('contact-form');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');
  const submitBtn = document.getElementById('submit-btn');

  const defaultError =
    'Не удалось отправить заявку. Напишите в Telegram или MAX — или позвоните по телефону.';

  function showError(message) {
    errorEl.textContent = message;
    errorEl.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Отправка...';
    successEl.classList.add('hidden');
    errorEl.classList.add('hidden');

    const formData = new FormData(form);
    const payload = {
      name: String(formData.get('name') || '').trim(),
      phone: String(formData.get('phone') || '').trim(),
      message: String(formData.get('message') || '').trim() || 'Без сообщения',
      consent: formData.get('consent') === 'yes' ? 'Да' : 'Нет',
      _subject: 'Новая заявка на консультацию — сайт Марины Шуваловой',
      _template: 'table',
    };

    // Bot filled honeypot — pretend success
    if (String(formData.get('_gotcha') || '').trim()) {
      form.reset();
      successEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = submitLabel;
      return;
    }

    try {
      const response = await fetch(formEndpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const data = await response.json().catch(() => ({}));
      const message = String(data.message || '');
      const ok = response.ok && (data.success === true || data.success === 'true');

      if (ok) {
        form.reset();
        successEl.textContent = successMessage;
        successEl.classList.remove('hidden');
        return;
      }

      if (/activat/i.test(message)) {
        showError(
          `Нужна одноразовая активация: откройте почту ${notifyEmail} (проверьте «Спам»), письмо от FormSubmit — нажмите Activate Form. После этого отправьте заявку ещё раз.`
        );
        return;
      }

      showError(message || defaultError);
    } catch {
      showError(defaultError);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = submitLabel;
    }
  });
</script>
