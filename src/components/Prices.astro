---
import site from '../content/site.json';
---

<section id="prices" class="section-padding">
  <div class="mx-auto max-w-6xl">
    <div class="fade-in mb-12 text-center">
      <h2 class="section-title">{site.prices.title}</h2>
      <p class="section-subtitle mx-auto">{site.prices.subtitle}</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        site.prices.items.map((item, index) => (
          <div
            class:list={[
              'card fade-in relative flex flex-col text-center',
              item.featured && 'ring-2 ring-sage/30',
            ]}
            style={`transition-delay: ${index * 80}ms`}
          >
            {item.badge && (
              <span class="absolute -top-3 right-4 rounded-full bg-sage px-3 py-1 text-xs font-bold text-white">
                {item.badge}
              </span>
            )}
            <h3 class:list={['font-serif text-xl font-medium text-stone', item.duration ? 'mb-2' : 'mb-4']}>
              {item.name}
            </h3>
            {item.duration && (
              <p class="mb-4 text-sm text-stone-muted">{item.duration}</p>
            )}
            {item.oldPrice && (
              <p class="text-sm text-stone-muted line-through">{item.oldPrice}</p>
            )}
            <p class="mb-4 font-serif text-4xl font-medium text-sage">{item.price}</p>
            <p class="mb-6 flex-1 text-sm text-stone-muted leading-relaxed">{item.note}</p>
            <a href="#contact" class="btn-outline w-full text-sm">
              {site.prices.ctaLabel}
            </a>
          </div>
        ))
      }
    </div>

    <p class="fade-in mt-8 text-center text-sm text-stone-muted">
      {site.prices.disclaimer}
    </p>
  </div>
</section>
