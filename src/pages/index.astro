---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ForWhom from '../components/ForWhom.astro';
import About from '../components/About.astro';
import Approach from '../components/Approach.astro';
import Services from '../components/Services.astro';
import Numerology from '../components/Numerology.astro';
import Format from '../components/Format.astro';
import Prices from '../components/Prices.astro';
import Process from '../components/Process.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
---

<Layout>
  <Header />
  <main class="pb-20 md:pb-0">
    <Hero />
    <ForWhom />
    <About />
    <Approach />
    <Services />
    <Numerology />
    <Format />
    <Prices />
    <Process />
    <Testimonials />
    <FAQ />
    <ContactForm />
  </main>
  <Footer />
  <MobileStickyCTA />
</Layout>
