---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../content/site.json';
---

<Layout
  title={`${site.privacy.title} — ${site.psychologist.name}`}
  description="Политика конфиденциальности и обработки персональных данных"
>
  <Header />
  <main class="pt-24">
    <article class="section-padding">
      <div class="prose prose-stone mx-auto max-w-3xl">
        <h1 class="section-title">{site.privacy.title}</h1>
        <p class="text-stone-muted">Последнее обновление: {site.privacy.lastUpdated}</p>

        {
          site.privacy.sections.map((section) => (
            <section class="mt-8">
              <h2 class="font-serif text-2xl font-medium text-stone">{section.title}</h2>
              <p class="mt-3 text-stone-muted leading-relaxed">{section.content}</p>
            </section>
          ))
        }

        <p class="mt-12">
          <a href="/" class="text-sage transition-colors hover:text-sage-dark">
            &larr; Вернуться на главную
          </a>
        </p>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
